# Copy to `.env` and fill in. Every Settings field in app/core/config.py can
# be overridden here.

# --- LLM (only needed for answer generation; everything else runs without it)
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash
# Local fallback: when Gemini fails (no/invalid key, offline, rate limit) the
# app automatically retries against Ollama — needs `ollama serve` running and
# a pulled model (`ollama pull qwen2.5`). Defaults shown; uncomment to change.
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5
# OLLAMA_TIMEOUT_S=180
# OLLAMA_NUM_CTX=8192
# OLLAMA_KEEP_ALIVE=30m

# --- Embeddings (locked default: code-trained BGE-M3, 1024-dim, ~2.3 GB
#     download on first run). Laptop-friendly alternative:
# EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
# EMBEDDING_DIM=384
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIM=1024

# --- Infrastructure
REDIS_URL=redis://localhost:6379/0
DATA_DIR=data
REPOS_DIR=data/repos

# --- Feature flags / tuning (sane defaults; see config.py for all knobs)
# QUERY_REWRITE_ENABLED=true
# GRAPH_EXPANSION_ENABLED=true
# GRAPH_EXPANSION_HOPS=1
# OKF_ON_INGEST=true
# LOG_JSON=true
